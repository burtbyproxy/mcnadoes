---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Client Portal" description="McNadoes Client Portal — Secure access for active McNadoes contract holders.">

  <div class="min-h-screen bg-offwhite flex items-center justify-center py-16 px-4">
    <div class="w-full max-w-md">

      <!-- Header lockup -->
      <div class="text-center mb-8">
        <h1 class="text-2xl font-bold text-navy">McNadoes Client Portal</h1>
        <p class="text-steel text-sm mt-2">Secure access for active contract holders.</p>
      </div>

      <!-- Login card -->
      <div class="bg-white border border-mist shadow-sm rounded-sm p-8">

        <div id="login-form-wrapper">
          <form id="login-form" class="space-y-5" novalidate>
            <div>
              <label for="email" class="block text-xs font-mono font-semibold text-navy/70 uppercase tracking-widest mb-2">
                Client Email Address
              </label>
              <input
                type="email"
                id="email"
                name="email"
                autocomplete="email"
                placeholder="you@yourcompany.com"
                class="w-full px-4 py-3 border border-mist bg-offwhite text-navy text-sm rounded-sm focus:outline-none focus:border-blue focus:ring-1 focus:ring-blue transition-colors font-mono"
                required
              />
            </div>

            <div>
              <label for="password" class="block text-xs font-mono font-semibold text-navy/70 uppercase tracking-widest mb-2">
                Password
              </label>
              <input
                type="password"
                id="password"
                name="password"
                autocomplete="current-password"
                placeholder="••••••••••••"
                class="w-full px-4 py-3 border border-mist bg-offwhite text-navy text-sm rounded-sm focus:outline-none focus:border-blue focus:ring-1 focus:ring-blue transition-colors font-mono"
                required
              />
            </div>

            <div class="flex items-center justify-between text-xs">
              <label class="flex items-center gap-2 text-steel cursor-pointer select-none">
                <input type="checkbox" class="accent-blue" />
                Keep me signed in
              </label>
              <a href="#" id="forgot-link" class="text-blue hover:text-blue-light font-mono transition-colors">Forgot password?</a>
            </div>

            <button
              type="submit"
              id="login-btn"
              class="w-full py-3 bg-blue text-white font-bold text-sm hover:bg-blue-light transition-colors rounded-sm flex items-center justify-center gap-2"
            >
              <span id="btn-label">Sign In to Portal</span>
              <svg id="btn-spinner" class="hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path>
              </svg>
            </button>
          </form>

          <div id="error-msg" class="hidden mt-4 p-4 bg-danger/5 border border-danger/20 rounded-sm">
            <p class="text-danger text-sm font-mono">
              No account was found with those credentials. Please verify your email address and try again, or contact your McNadoes account representative.
            </p>
          </div>

          <div id="forgot-msg" class="hidden mt-4 p-4 bg-blue/5 border border-blue/20 rounded-sm">
            <p class="text-blue text-sm font-mono">
              If an account exists for that email, a reset link has been sent. Please allow up to 15 minutes for delivery, then check your spam folder before calling us.
            </p>
          </div>
        </div>

        <div class="mt-8 pt-6 border-t border-mist text-center">
          <p class="text-xs text-steel/60 font-mono">
            Not a McNadoes client yet?
          </p>
          <a href="/contact" class="text-xs text-blue font-mono hover:text-blue-light transition-colors">
            Request a project quote →
          </a>
        </div>
      </div>

      <!-- Security badge -->
      <div class="mt-6 flex items-center justify-center gap-3 text-xs font-mono text-steel/50">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
        256-bit TLS encryption · McNadoes Secure Infrastructure
      </div>
    </div>
  </div>

</BaseLayout>

<script>
  const form = document.getElementById('login-form') as HTMLFormElement;
  const btn = document.getElementById('login-btn') as HTMLButtonElement;
  const btnLabel = document.getElementById('btn-label') as HTMLSpanElement;
  const spinner = document.getElementById('btn-spinner') as SVGSVGElement;
  const errorMsg = document.getElementById('error-msg') as HTMLDivElement;
  const forgotMsg = document.getElementById('forgot-msg') as HTMLDivElement;
  const forgotLink = document.getElementById('forgot-link') as HTMLAnchorElement;

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    errorMsg.classList.add('hidden');
    btnLabel.textContent = 'Authenticating...';
    spinner.classList.remove('hidden');
    btn.disabled = true;

    setTimeout(() => {
      btnLabel.textContent = 'Sign In to Portal';
      spinner.classList.add('hidden');
      btn.disabled = false;
      errorMsg.classList.remove('hidden');
    }, 2200);
  });

  forgotLink.addEventListener('click', (e) => {
    e.preventDefault();
    forgotMsg.classList.toggle('hidden');
  });
</script>
